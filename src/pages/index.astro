---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

// const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// const last_posts = posts.slice(0, 3);
//https://tailwindcss.com/docs/text-color
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-4xl font-bold">I'm Yi Zhang</div>
    <div class="text-2xl py-3">A lifelong learner</div>
    <div class="py-2">
      <text class="text-base text-neutral-600">
        <p class="mb-3">I am an HCI researcher, currently working as a Research Assistant 
          in the Computer Science Department at the University of Rochester, 
           supervised by <a href="https://zhenbai.io/" class="text-black-500 underline">Prof. Zhen Bai</a>, and as a member of the Interplay Lab. 
          I am also a member of the Digital Learning Lab at UC Irvine, led by <a href="https://markwarschauer.com/" class="text-black-500 underline">Prof. Mark Warschauer</a>.
        </p>
        <p class="mb-3">
        My research interests lie in Human-Computer Interaction, Educational Technology, AI Ethics, Social Computing. 
        I am passionate about using technology for social good and exploring the ethical, political, and cultural impacts of technical systems.
        </p>
        <p class="mb-3">
          I earned my B.A. in Japanese Language and Literature from Renmin University of China, which is renowned for its strength in the humanities and social sciences.
          I am grateful for my time there, where I freely explored various fields, including Law, Literature, Communication and Computer Science. 
          I also had the opportunity to study as an exchange student at Keio University in Tokyo, Japan, which was one of the happiest times of my life. 
          While at Renmin University, a class on Journalism & Algorithms sparked my passion for the intersection of technology and social science, leading me to begin studying and conducting research in Computer Science and Human-Computer Interaction.
        Later, I obtained my Master’s degree in Software Engineering from the University of California, Irvine.
        </p>
        <p class="mb-3">
          I am deeply passionate about interdisciplinary research, learning and product knowledge, 
          which has driven me to further pursue a Ph.D. degree.
          Outside of research, I love literature, movies, and enjoy writing and photography. If you would like to know more about me, 
          feel free to visit my blog.
        </p>

      </text>
    </div>
    <div class="mt-8">
      <!-- <a class="btn" href="https://twitter.com/manuelernestog" target="_blank"> Let's connect!</a> -->
    </div>
  </div>

